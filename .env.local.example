# ============================================================================
# Variables de entorno para el FRONTEND (React + Vite)
# Copiar a .env.local y reemplazar con valores reales.
# ============================================================================

# URL de las Edge Functions de Supabase
# La encuentras en: Supabase Dashboard > Settings > API > Edge Functions
VITE_SUPABASE_FUNCTIONS_URL=https://TU-PROYECTO.supabase.co/functions/v1

# Supabase Anon Key (clave pública, se puede exponer en el frontend)
# La encuentras en: Supabase Dashboard > Settings > API > anon/public key
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL del proyecto Supabase (para el cliente JS, si se usa en el frontend)
# La encuentras en: Supabase Dashboard > Settings > API > Project URL
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
